# TanyelOS system-wide dconf defaults
# These apply to every user on the system (live session + installed)
# Users can still override in their own profile

[org/gnome/desktop/interface]
gtk-theme='TanyelOS'
icon-theme='Yaru-teal-dark'
cursor-theme='Adwaita'
font-name='Inter 10'
monospace-font-name='JetBrains Mono 10'
document-font-name='Inter 10'
color-scheme='prefer-dark'
enable-animations=true

[org/gnome/desktop/background]
picture-options='zoom'
primary-color='#1B1F2A'
secondary-color='#252935'
color-shading-type='vertical'
picture-uri=''
picture-uri-dark=''

[org/gnome/desktop/wm/preferences]
button-layout='close,minimize,maximize:'
theme='TanyelOS'
titlebar-font='Inter Semi-Bold 10'
num-workspaces=4
action-double-click-titlebar='toggle-maximize'

[org/gnome/desktop/wm/keybindings]
show-desktop=['<Super>d']

[org/gnome/shell]
enabled-extensions=['dash-to-panel@jderose9.github.com', 'arcmenu@arcmenu.com', 'blur-my-shell@aunetx', 'user-theme@gnome-shell-extensions.gcampax.github.com', 'just-perfection-desktop@just-perfection']
favorite-apps=['org.gnome.Nautilus.desktop', 'org.gnome.Terminal.desktop', 'firefox.desktop', 'org.gnome.Settings.desktop']

[org/gnome/shell/extensions/user-theme]
name='TanyelOS'

[org/gnome/shell/extensions/dash-to-panel]
panel-positions='{"0":"BOTTOM"}'
panel-sizes='{"0":48}'
dot-style-focused='METRO'
dot-style-unfocused='DOTS'
dot-color-1='#2B9EA8'
dot-color-2='#2B9EA8'
dot-color-3='#2B9EA8'
dot-color-4='#2B9EA8'
trans-use-custom-bg=true
trans-bg-color='#2C3141'
trans-use-custom-opacity=true
trans-panel-opacity=0.78
group-apps=false
show-appmenu=false
show-running-apps=true
show-favorites=true
click-action='CYCLE-MIN'
panel-element-positions='{"0":[{"element":"showAppsButton","visible":true,"position":"stackedTL"},{"element":"activitiesButton","visible":false,"position":"stackedTL"},{"element":"leftBox","visible":true,"position":"stackedTL"},{"element":"taskbar","visible":true,"position":"stackedTL"},{"element":"centerBox","visible":false,"position":"stackedBR"},{"element":"rightBox","visible":true,"position":"stackedBR"},{"element":"systemMenu","visible":true,"position":"stackedBR"},{"element":"dateMenu","visible":true,"position":"stackedBR"},{"element":"desktopButton","visible":true,"position":"stackedBR"}]}'

[org/gnome/shell/extensions/arcmenu]
menu-button-position='Left'
menu-button-appearance='Text'
custom-menu-button-text='Start'
menu-layout='Eleven'
menu-width-adjustment=360
menu-border-radius=14
menu-color='rgba(44,49,65,0.85)'
menu-border-color='rgba(58,63,82,0.8)'
show-power-options=true
default-menu-view='Pinned_Apps'

[org/gnome/shell/extensions/blur-my-shell]
sigma=20
brightness=0.8

[org/gnome/shell/extensions/blur-my-shell/panel]
blur=true
unblur-dynamically=true

[org/gnome/shell/extensions/blur-my-shell/dash-to-panel]
blur=true

[org/gnome/shell/extensions/just-perfection]
activities-button=false
app-menu=false
search=true
workspace=false
workspace-popup=false

[org/gnome/mutter]
dynamic-workspaces=true
edge-tiling=true

[org/gnome/login-screen]
disable-user-list=false
banner-message-enable=false
